VIBESHIFT_APP_ENV=development
VIBESHIFT_REQUEST_TIMEOUT_SECONDS=180
VIBESHIFT_LOCAL_LLM_REQUEST_TIMEOUT_SECONDS=420
VIBESHIFT_FETCH_TIMEOUT_SECONDS=15
VIBESHIFT_CACHE_TTL_SECONDS=3600
VIBESHIFT_CACHE_MAX_ENTRIES=256
VIBESHIFT_SEARXNG_ENGINES=baidu,github
VIBESHIFT_MAX_INPUT_CHARACTERS=50000
VIBESHIFT_MAX_URL_INPUTS=8
VIBESHIFT_REWRITE_CHUNK_SIZE_CHARACTERS=6000
VIBESHIFT_REWRITE_CHUNK_OVERLAP_CHARACTERS=500
VIBESHIFT_REWRITE_MAX_CONCURRENCY=3
VIBESHIFT_RUNS_DIRECTORY=.runs
VIBESHIFT_ARTIFACT_PREVIEW_CHARACTERS=1600
VIBESHIFT_CORS_ORIGINS=["*"]
VIBESHIFT_USER_AGENT="VibeShiftBot/0.1 (+https://example.local)"
